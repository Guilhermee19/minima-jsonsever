{
  "name": "minima-jsonserver",
  "version": "1.0.0",
  "description": "JSON Server API com PM2",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:https": "HTTPS=true node index.js",
    "dev": "nodemon index.js",
    "dev:https": "HTTPS=true nodemon index.js",
    "tunnel": "npx ngrok http 3003",
    "tunnel:secure": "npx ngrok http 3003 --region us --log stdout",
    "ssl:generate": "./generate-ssl.sh",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:start:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:stop": "pm2 stop minima-jsonserver",
    "pm2:restart": "pm2 restart minima-jsonserver",
    "pm2:logs": "pm2 logs minima-jsonserver",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete minima-jsonserver"
  },
  "keywords": [
    "json-server",
    "api",
    "rest",
    "pm2",
    "nodejs"
  ],
  "author": "Guilherme",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
