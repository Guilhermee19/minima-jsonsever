# Configurações do Servidor JSON
# Copie este arquivo para .env e ajuste conforme necessário

# Porta do servidor (padrão: 3003)
PORT=3003

# Host do servidor
# Para desenvolvimento: localhost
# Para produção: 0.0.0.0 (aceita conexões externas)
HOST=0.0.0.0

# Ambiente de execução
NODE_ENV=production

# Configurações opcionais do JSON Server (não implementadas por padrão)
# JSON_SERVER_HOST=0.0.0.0
# JSON_SERVER_PORT=3003
# JSON_SERVER_DELAY=0
# JSON_SERVER_CORS=true