{
  "watch": [
    "index.js",
    "db.json",
    "src/"
  ],
  "ignore": [
    "node_modules/",
    "logs/",
    "*.log",
    ".git/",
    "dist/",
    "build/",
    "coverage/",
    ".nyc_output/"
  ],
  "ext": "js,json,mjs",
  "env": {
    "NODE_ENV": "development",
    "PORT": "3003",
    "HOST": "localhost"
  },
  "delay": 1000,
  "verbose": true,
  "restartable": "rs",
  "colours": true,
  "legacyWatch": false,
  "pollingInterval": 100,
  "runOnChangeOnly": false,
  "signal": "SIGTERM",
  "events": {
    "restart": "echo '🔄 Reiniciando servidor JSON...'",
    "crash": "echo '💥 Erro no servidor!'",
    "start": "echo '🚀 JSON Server iniciado com nodemon'"
  },
  "exec": "node index.js"
}